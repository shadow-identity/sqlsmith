{
	"name": "sqlsmith-workspace",
	"version": "0.5.0",
	"description": "SQLsmith monorepo - SQL schema merging tools",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"check:refactoring-plan": "node scripts/check-refactoring-plan.mjs",
		"check:refactoring-plan:complete": "node scripts/check-refactoring-plan.mjs --require-executable",
		"test": "pnpm build && pnpm -r test",
		"clean": "pnpm -r exec rm -rf dist",
		"dev:cli": "pnpm --filter @sqlsmith/cli dev",
		"dev:core": "pnpm --filter @sqlsmith/core test:watch",
		"version:patch": "node scripts/version-bump.js patch",
		"version:minor": "node scripts/version-bump.js minor",
		"version:major": "node scripts/version-bump.js major"
	},
	"keywords": [
		"sql",
		"merge",
		"database",
		"schema",
		"dependency",
		"topological-sort",
		"ast",
		"cli",
		"vite",
		"plugin"
	],
	"author": {
		"name": "Pavel Nedrigailov"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/shadow-identity/sqlsmith.git"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@types/node": "^24.0.0",
		"typescript": "^5.8.3"
	},
	"packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
